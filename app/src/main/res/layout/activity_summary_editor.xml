<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_dark"/>

    <!-- Formatting toolbar — HorizontalScrollView supaya tidak terpotong -->
    <HorizontalScrollView
        android:layout_width="match_parent" android:layout_height="52dp"
        android:background="@color/surface_dark"
        android:scrollbars="none"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="12dp">

            <!-- Undo ← -->
            <TextView android:id="@+id/btnUndo"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="←" android:textSize="18sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="2dp"/>

            <View android:layout_width="1dp" android:layout_height="24dp"
                android:background="@color/divider" android:layout_marginHorizontal="4dp"/>

            <!-- Font size H -->
            <TextView android:id="@+id/btnHeading"
                android:layout_width="44dp" android:layout_height="36dp"
                android:text="M" android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="@drawable/bg_btn_secondary"
                android:layout_marginEnd="4dp"/>

            <!-- Bold B -->
            <TextView android:id="@+id/btnBold"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="B" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="2dp"/>

            <!-- Italic I -->
            <TextView android:id="@+id/btnItalic"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="I" android:textSize="15sp" android:textStyle="italic"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="2dp"/>

            <!-- Strike S -->
            <TextView android:id="@+id/btnStrike"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="S" android:textSize="15sp"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="2dp"/>

            <View android:layout_width="1dp" android:layout_height="24dp"
                android:background="@color/divider" android:layout_marginHorizontal="4dp"/>

            <!-- Bullet -->
            <TextView android:id="@+id/btnBullet"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="•≡" android:textSize="14sp"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="2dp"/>

            <!-- Number -->
            <TextView android:id="@+id/btnNumber"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="1≡" android:textSize="14sp"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="2dp"/>

            <View android:layout_width="1dp" android:layout_height="24dp"
                android:background="@color/divider" android:layout_marginHorizontal="4dp"/>

            <!-- Indent → -->
            <TextView android:id="@+id/btnIndent"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="→" android:textSize="16sp"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="2dp"/>

            <!-- Outdent ← -->
            <TextView android:id="@+id/btnOutdent"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="←" android:textSize="16sp"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="2dp"/>

            <View android:layout_width="1dp" android:layout_height="24dp"
                android:background="@color/divider" android:layout_marginHorizontal="4dp"/>

            <!-- Redo ↺ -->
            <TextView android:id="@+id/btnRedo"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="↺" android:textSize="18sp"
                android:textColor="@color/text_secondary" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Editor area -->
    <EditText android:id="@+id/etSummary"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="top|start"
        android:padding="16dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:lineSpacingExtra="6dp"
        android:background="@color/bg_dark"
        android:inputType="textMultiLine|textCapSentences"/>

</LinearLayout>
