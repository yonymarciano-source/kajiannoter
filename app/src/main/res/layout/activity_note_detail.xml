<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface_dark">
        <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/text_primary" app:navigationIconTint="@color/text_primary"/>
        <com.google.android.material.tabs.TabLayout android:id="@+id/tabLayout"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@color/surface_dark"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/primary_green"
            app:tabIndicatorColor="@color/primary_green"
            app:tabMode="fixed"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView android:id="@+id/scrollTranscript"
        android:layout_width="match_parent" android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView android:id="@+id/tvTitle"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary" android:textSize="20sp"
                    android:textStyle="bold"/>
                <ImageButton android:id="@+id/btnEditTitle"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_edit"
                    android:tint="@color/text_secondary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
            <TextView android:id="@+id/tvMeta"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvSpeakerCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/primary_green" android:textSize="12sp"
                android:layout_marginBottom="12dp" android:visibility="gone"/>

            <!-- Audio Player Card -->
            <androidx.cardview.widget.CardView android:id="@+id/cardPlayer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" android:visibility="gone"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_dark">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎵 Audio Kajian" android:textColor="@color/primary_green"
                        android:textSize="12sp" android:textStyle="bold" android:layout_marginBottom="10dp"/>
                    <FrameLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">
                        <SeekBar android:id="@+id/seekBar" android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:progressTint="@color/primary_green"
                            android:thumbTint="@color/primary_green"/>
                        <com.kajian.note.ui.BookmarkOverlayView
                            android:id="@+id/bookmarkOverlay"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:id="@+id/tvCurrentTime" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="00:00"
                            android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                        <TextView android:id="@+id/tvTotalTime" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="00:00"
                            android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center">
                        <Button android:id="@+id/btnSpeed" android:layout_width="56dp"
                            android:layout_height="36dp" android:text="1.0x" android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_btn_secondary"
                            android:stateListAnimator="@null" android:layout_marginEnd="8dp"/>
                        <ImageButton android:id="@+id/btnSkipBack" android:layout_width="44dp"
                            android:layout_height="44dp" android:src="@drawable/ic_skip_back"
                            android:tint="@color/text_primary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:layout_marginEnd="4dp"/>
                        <ImageButton android:id="@+id/btnPlayPause" android:layout_width="56dp"
                            android:layout_height="56dp" android:src="@android:drawable/ic_media_play"
                            android:tint="@color/bg_dark" android:backgroundTint="@color/primary_green"
                            android:background="@drawable/bg_circle" android:layout_marginEnd="4dp"/>
                        <ImageButton android:id="@+id/btnSkipForward" android:layout_width="44dp"
                            android:layout_height="44dp" android:src="@drawable/ic_skip_forward"
                            android:tint="@color/text_primary"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </LinearLayout>
                    <!-- Bookmark row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center"
                        android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnBookmark" android:layout_width="wrap_content"
                            android:layout_height="36dp" android:text="⭐ Tandai"
                            android:textSize="12sp" android:textColor="@color/text_primary"
                            android:background="@drawable/bg_btn_secondary"
                            android:stateListAnimator="@null" android:layout_marginEnd="12dp"
                            android:paddingStart="12dp" android:paddingEnd="12dp"/>
                        <Button android:id="@+id/btnBookmarkJump" android:layout_width="wrap_content"
                            android:layout_height="36dp" android:text="⭐ 0"
                            android:textSize="12sp" android:textColor="@color/primary_green"
                            android:background="@drawable/bg_btn_secondary"
                            android:stateListAnimator="@null"
                            android:paddingStart="12dp" android:paddingEnd="12dp"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp" android:weightSum="3">
                <Button android:id="@+id/btnShare" style="@style/ActionBtnSecondary"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:layout_marginEnd="6dp" android:text="@string/btn_share"/>
                <Button android:id="@+id/btnCopy" style="@style/ActionBtnSecondary"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:layout_marginEnd="6dp" android:text="@string/btn_copy"/>
                <ImageButton android:id="@+id/btnEdit" android:layout_width="0dp"
                    android:layout_height="44dp" android:layout_weight="1"
                    android:background="@drawable/bg_btn_secondary" android:src="@drawable/ic_edit"
                    android:tint="@color/text_secondary" android:padding="10dp"/>
            </LinearLayout>
            <Button android:id="@+id/btnExport" android:layout_width="match_parent"
                android:layout_height="44dp" android:layout_marginBottom="8dp"
                android:text="⬇ Export PDF / Word" android:textColor="@color/bg_dark"
                android:textStyle="bold" android:textSize="13sp"
                android:backgroundTint="@color/primary_green" android:stateListAnimator="@null"/>
            <Button android:id="@+id/btnMoveFolder" android:layout_width="match_parent"
                android:layout_height="40dp" android:layout_marginBottom="12dp"
                android:text="📁 Pindah Folder" android:textColor="@color/text_secondary"
                android:textSize="13sp" android:backgroundTint="@color/surface_variant"
                android:stateListAnimator="@null" android:visibility="gone"/>

            <!-- PANEL: Transcript -->
            <LinearLayout android:id="@+id/panelTranscript"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:id="@+id/tvTranscript"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:lineSpacingExtra="8dp" android:layout_marginBottom="80dp"/>
                <EditText android:id="@+id/etTranscriptEdit"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:minHeight="200dp" android:gravity="top|start"
                    android:background="@drawable/bg_transcript" android:padding="12dp"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    android:lineSpacingExtra="6dp" android:inputType="textMultiLine|textCapSentences"
                    android:visibility="gone" android:layout_marginBottom="80dp"/>
            </LinearLayout>

            <!-- PANEL: Translate -->
            <LinearLayout android:id="@+id/panelTranslate"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <!-- Language selector -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Terjemahkan ke:" android:textColor="@color/text_secondary"
                        android:textSize="13sp" android:layout_marginEnd="12dp"/>
                    <TextView android:id="@+id/chipTranslateId"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="🇮🇩 Indonesia" android:textSize="12sp" android:gravity="center"
                        android:paddingHorizontal="14dp" android:background="@drawable/bg_chip_active"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/chipTranslateEn"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="🇬🇧 English" android:textSize="12sp" android:gravity="center"
                        android:paddingHorizontal="14dp" android:background="@drawable/bg_chip_inactive"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>

                <TextView android:id="@+id/tvTranslateEmpty"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="14sp"
                    android:lineSpacingExtra="6dp" android:gravity="center"
                    android:padding="24dp" android:visibility="gone"/>

                <androidx.cardview.widget.CardView android:id="@+id/cardTranslateContent"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp" android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp" app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_dark">
                    <TextView android:id="@+id/tvTranslateContent"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp"
                        android:lineSpacingExtra="6dp" android:padding="16dp"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="80dp">
                    <Button android:id="@+id/btnTranslate" android:layout_width="match_parent"
                        android:layout_height="44dp" android:text="🌐 Terjemahkan"
                        android:textColor="@color/bg_dark" android:textStyle="bold" android:textSize="13sp"
                        android:backgroundTint="@color/primary_green" android:stateListAnimator="@null"
                        android:layout_marginBottom="8dp"/>
                    <Button android:id="@+id/btnExportTranslate" android:layout_width="match_parent"
                        android:layout_height="40dp" android:text="⬇ Export Terjemahan"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:backgroundTint="@color/surface_variant" android:stateListAnimator="@null"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>

            <!-- PANEL: Summary -->
            <LinearLayout android:id="@+id/panelSummary"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView android:id="@+id/tvSummaryEmpty"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="14sp"
                    android:lineSpacingExtra="6dp" android:gravity="center"
                    android:padding="24dp" android:visibility="gone"/>

                <androidx.cardview.widget.CardView android:id="@+id/cardSummaryContent"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" android:visibility="gone"
                    app:cardCornerRadius="12dp" app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/surface_dark">
                    <TextView android:id="@+id/tvSummaryContent"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp"
                        android:lineSpacingExtra="6dp" android:padding="16dp"/>
                </androidx.cardview.widget.CardView>

                <!-- Summary action buttons -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <Button android:id="@+id/btnGenerateSummary" android:layout_width="match_parent"
                        android:layout_height="44dp" android:text="✦ Generate Ringkasan AI"
                        android:textColor="@color/bg_dark" android:textStyle="bold" android:textSize="13sp"
                        android:backgroundTint="@color/primary_green" android:stateListAnimator="@null"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="3"
                    android:layout_marginBottom="80dp">
                    <Button android:id="@+id/btnEditSummary" style="@style/ActionBtnSecondary"
                        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                        android:layout_marginEnd="6dp" android:text="✏ Edit" android:visibility="gone"/>
                    <Button android:id="@+id/btnRedoSummary" style="@style/ActionBtnSecondary"
                        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                        android:layout_marginEnd="6dp" android:text="↻ Redo" android:visibility="gone"/>
                    <Button android:id="@+id/btnSaveSummary"
                        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                        android:text="✓ Simpan" android:textColor="@color/bg_dark" android:textStyle="bold"
                        android:backgroundTint="@color/primary_green" android:stateListAnimator="@null"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>

            <!-- PANEL: Poin Kunci (replaces Mindmap) -->
            <LinearLayout android:id="@+id/panelMindmap"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">
                <TextView android:id="@+id/tvPoinKunciLoading"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⏳ Membuat Poin Kunci via Groq AI..."
                    android:textColor="@color/text_secondary" android:textSize="14sp"
                    android:gravity="center" android:padding="24dp"/>
                <LinearLayout android:id="@+id/llPoinKunciCards"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:visibility="gone"
                    android:layout_marginBottom="80dp"/>
                <Button android:id="@+id/btnGeneratePoinKunci" android:layout_width="match_parent"
                    android:layout_height="44dp" android:text="🔑 Generate Poin Kunci"
                    android:textColor="@color/bg_dark" android:textStyle="bold" android:textSize="13sp"
                    android:backgroundTint="@color/primary_green"
                    android:stateListAnimator="@null" android:visibility="gone"
                    android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnExportPoinKunci" android:layout_width="match_parent"
                    android:layout_height="40dp" android:text="⬇ Export Poin Kunci"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:backgroundTint="@color/surface_variant" android:stateListAnimator="@null"
                    android:visibility="gone" android:layout_marginBottom="80dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
