<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="12dp"
    android:paddingHorizontal="4dp">

    <!-- Accent bar kiri (warna speaker) -->
    <View
        android:id="@+id/viewSpeakerAccent"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="10dp"
        android:background="@color/speaker_a"/>

    <!-- Konten -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Header: label speaker + timestamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvSpeakerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speaker A"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:background="@drawable/bg_speaker_badge"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="11sp"
                android:textColor="@color/text_tertiary"/>

        </LinearLayout>

        <!-- Teks transkripsi -->
        <TextView
            android:id="@+id/tvSegmentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:background="@drawable/bg_segment_bubble"
            android:padding="10dp"/>

    </LinearLayout>

</LinearLayout>
