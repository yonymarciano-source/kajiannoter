<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Close button -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:background="@color/surface_variant"
            android:src="@drawable/ic_back"
            android:tint="@color/text_secondary"
            android:contentDescription="Tutup"/>

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="⭐"
            android:textSize="48sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvPaywallTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Upgrade KajianNote"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvPaywallSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Buka semua fitur untuk pengalaman menuntut ilmu terbaik."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"/>

        <!-- One-Time Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEKALI BAYAR"
                    android:textColor="@color/primary_green"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Premium"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Rp 49.000"
                    android:textColor="@color/primary_green"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="✅  Catatan tak terbatas"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="✅  Export PDF &amp; Word"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="✅  Folder &amp; kategori kajian"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="✅  Bayar sekali, selamanya"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuyOnetime"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="Beli Sekarang — Rp 49.000"
                    android:textColor="@color/bg_dark"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary_green"
                    app:cornerRadius="14dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Subscription Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface_elevated"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LANGGANAN BULANAN"
                    android:textColor="@color/accent_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Subscriber"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Rp 15.000"
                        android:textColor="@color/accent_blue"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="/bulan"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"/>
                </LinearLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="✅  Semua fitur Premium"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="🎤  Speaker diarization (Ustadz/Jamaah)"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="🌙  Terjemah Arab → Indonesia otomatis"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:text="☁️  Backup cloud otomatis"
                    android:textColor="@color/text_secondary" android:textSize="13sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubscribe"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="Langganan — Rp 15.000/bulan"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/accent_blue"
                    app:cornerRadius="14dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Info Rekening Transfer -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💳 Transfer ke salah satu rekening"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvBankInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mandiri: 1570005373924 a.n Yony Marciano\nBCA: 8010198454 a.n Yony Marciano\nGopay/OVO: 087872390906 a.n Yony Marciano"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"/>

                <Button
                    android:id="@+id/btnCopyBankInfo"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:text="📋 Salin Info Rekening"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:backgroundTint="@color/surface_variant"
                    android:stateListAnimator="@null"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Warning: data harus sesuai email login -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Penting"
                    android:textColor="@color/accent_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/tvWarningEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pastikan nama &amp; email yang dikirim SAMA dengan email login KajianNote kamu. Verifikasi tidak bisa dilakukan jika data tidak sesuai."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Already paid -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlreadyPaid"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Sudah bayar? Verifikasi di sini"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

    </LinearLayout>
</ScrollView>
