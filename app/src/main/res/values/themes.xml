<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KajianNote" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_green_dark</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorControlNormal">@color/text_tertiary</item>
        <item name="colorControlActivated">@color/primary_green</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.KajianNote.Splash" parent="Theme.KajianNote">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">12sp</item>
        <item name="textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="ActionBtnPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_green</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="ActionBtnSecondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/surface_variant</item>
        <item name="backgroundTint">@color/surface_elevated</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="CardStyle" parent="">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface_dark</item>
    </style>
</resources>