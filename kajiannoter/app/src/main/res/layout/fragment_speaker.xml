<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- API Key Warning Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardApiKeyWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A1A2E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ AssemblyAI API Key belum diset"
                    android:textColor="@color/accent_gold"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Daftar gratis di assemblyai.com untuk fitur identifikasi speaker."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btnSetApiKey"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Set API Key"
                    android:textSize="12sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/bg_btn_primary"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Config Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Jumlah Speaker -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👥 Jumlah Speaker"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/chipSpeakerAuto"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Auto"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/bg_chip_inactive"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipSpeaker2"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="2"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/bg_chip_active"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipSpeaker3"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="3"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/bg_chip_inactive"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipSpeaker4"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="4+"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/bg_chip_inactive"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <!-- Label Speaker -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏷️ Label Speaker (opsional)"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutSpeakerLabels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp"/>

                <!-- Bahasa Audio -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌐 Bahasa Audio"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/chipLangId"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="🇮🇩 Indonesia"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/bg_chip_active"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipLangAr"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="🌙 Arab"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/bg_chip_inactive"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipLangAuto"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="🌐 Auto"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/bg_chip_inactive"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Timer & Record Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/text_primary"
                    android:textSize="40sp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvRecordStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Siap merekam"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/primary_green"
                    android:trackTint="@color/surface_variant"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"/>

                <ImageButton
                    android:id="@+id/btnRecord"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_mic"
                    android:background="@drawable/bg_record_btn"
                    android:padding="16dp"
                    android:stateListAnimator="@null"
                    android:contentDescription="Rekam"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Transcript / Segments -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎙️ Transkripsi per Speaker"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="12dp"/>

                <!-- Placeholder -->
                <TextView
                    android:id="@+id/tvPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap tombol rekam untuk mulai mencatat kajian."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="24dp"/>

                <!-- Segments list -->
                <LinearLayout
                    android:id="@+id/segmentsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSegments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveNote"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="SIMPAN CATATAN"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"
            android:enabled="false"
            android:alpha="0.5"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
